<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Chronicle.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Chronicle"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Chronicle">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <!-- Root: Sidebar (fixed) | Main content (fills remaining space) -->
    <Grid x:Name="RootGrid" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════════════════
             Left Sidebar
             ═══════════════════════════════════════════════════════ -->
        <Border Grid.Column="0"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,0,1,0"
                Background="{ThemeResource LayerFillColorDefaultBrush}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Padding="16,20,16,16" Spacing="20">
                    <!-- Mini Month Navigator -->
                    <StackPanel x:Name="MiniMonthPanel" Spacing="2"/>
                    <!-- Selected Day detail (date, event count, events) -->
                    <StackPanel x:Name="SelectedDayPanel" Spacing="6"/>
                    <!-- Calendars list / visibility toggles -->
                    <StackPanel x:Name="SidebarPanel" Spacing="4"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ═══════════════════════════════════════════════════════
             Main Calendar Area
             ═══════════════════════════════════════════════════════ -->
        <Grid Grid.Column="1" Padding="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Navigation Header -->
            <Grid Grid.Row="0" Height="50" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Navigation Buttons (Left). Previous/Next move by month in
                     Month view and by week in Week view. -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <Button x:Name="PrevMonthButton" Content="Previous" Padding="12,6"/>
                    <Button x:Name="TodayButton" Content="Today" Padding="12,6"/>
                    <Button x:Name="NextMonthButton" Content="Next" Padding="12,6"/>
                </StackPanel>

                <!-- Period Text (Center): month name or week range -->
                <TextBlock
                    x:Name="MonthYearText"
                    Grid.Column="1"
                    Text="June 2026"
                    FontSize="28"
                    FontWeight="Bold"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"/>

                <!-- View Switcher (Right): Month / Week -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="0" VerticalAlignment="Center">
                    <ToggleButton x:Name="MonthViewToggle" Content="Month" Padding="12,6" IsChecked="True"/>
                    <ToggleButton x:Name="WeekViewToggle" Content="Week" Padding="12,6"/>
                </StackPanel>
            </Grid>

            <!-- Month View -->
            <Grid x:Name="MonthViewRoot" Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Day Name Headers (Sun–Sat) -->
                <Grid x:Name="DayNamesGrid" Grid.Row="0" Height="40">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                </Grid>

                <!-- Calendar Grid (7 columns, variable rows) -->
                <Grid x:Name="CalendarGrid" Grid.Row="1"/>
            </Grid>

            <!-- Week View (7 day columns; populated by WeekViewRenderer) -->
            <Grid x:Name="WeekViewRoot" Grid.Row="1" Visibility="Collapsed"/>
        </Grid>
    </Grid>
</Window>
