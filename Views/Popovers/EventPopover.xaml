<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Chronicle.Views.Popovers.EventPopover"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Chronicle.Views.Popovers"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!-- Card content for the event popover. Hosted as the Content of a
         Flyout (see MainWindow.xaml.cs), so the Flyout itself provides the
         pointer-blur light-dismiss behavior. -->
    <StackPanel Width="280" Spacing="10">

        <!-- Accent bar tinted to the event's calendar color -->
        <Border x:Name="AccentBar"
                Width="38" Height="4"
                CornerRadius="2"
                HorizontalAlignment="Left"
                Margin="0,0,0,2"/>

        <!-- Event title -->
        <TextBlock x:Name="TitleText"
                   FontSize="16"
                   FontWeight="SemiBold"
                   TextWrapping="Wrap"/>

        <!-- Time range -->
        <TextBlock x:Name="TimeRangeText"
                   FontSize="13"
                   Opacity="0.75"/>

        <!-- Location (shown only when present) -->
        <TextBlock x:Name="LocationText"
                   FontSize="13"
                   Opacity="0.75"
                   TextWrapping="Wrap"
                   Visibility="Collapsed"/>

        <!-- Description preview (shown only when present) -->
        <TextBlock x:Name="DescriptionText"
                   FontSize="13"
                   TextWrapping="Wrap"
                   MaxLines="3"
                   TextTrimming="CharacterEllipsis"
                   Visibility="Collapsed"/>

        <!-- Delete confirmation message -->
        <TextBlock x:Name="StatusText"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                   Visibility="Collapsed"/>

        <!-- Actions -->
        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
            <Button x:Name="DeleteButton" Content="Delete" Click="DeleteButton_Click"/>
            <Button x:Name="EditButton" Content="Edit"
                    Style="{StaticResource AccentButtonStyle}"
                    Click="EditButton_Click"/>
            <Button x:Name="CloseButton" Content="Close" Click="CloseButton_Click"/>
        </StackPanel>

    </StackPanel>
</UserControl>
