<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Chronicle.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Chronicle"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Chronicle">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <!-- Root: Sidebar (fixed) | Main content (fills remaining space) -->
    <Grid x:Name="RootGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════════════════
             Left Sidebar  (elevated dark surface)
             ═══════════════════════════════════════════════════════ -->
        <Border Grid.Column="0"
                Background="#232427"
                BorderBrush="#17FFFFFF"
                BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Padding="14,16,14,18" Spacing="22">
                    <!-- Mini Month Navigator -->
                    <StackPanel x:Name="MiniMonthPanel" Spacing="2"/>
                    <!-- Selected Day detail (date, event count, events) -->
                    <StackPanel x:Name="SelectedDayPanel" Spacing="6"/>
                    <!-- Calendars list / visibility toggles -->
                    <StackPanel x:Name="SidebarPanel" Spacing="2"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ═══════════════════════════════════════════════════════
             Main Calendar Area
             ═══════════════════════════════════════════════════════ -->
        <Grid Grid.Column="1" Padding="18,14,18,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Navigation Header -->
            <Grid Grid.Row="0" Height="48" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left group: Today, prev/next chevrons, period title.
                     Previous/Next move by month in Month view, by week in Week view. -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Button x:Name="TodayButton" Content="Today" Padding="16,6"/>
                    <StackPanel Orientation="Horizontal" Spacing="2">
                        <Button x:Name="PrevMonthButton" Width="34" Height="34" Padding="0"
                                Background="Transparent" BorderThickness="0"
                                ToolTipService.ToolTip="Previous">
                            <FontIcon Glyph="&#xE76B;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                        </Button>
                        <Button x:Name="NextMonthButton" Width="34" Height="34" Padding="0"
                                Background="Transparent" BorderThickness="0"
                                ToolTipService.ToolTip="Next">
                            <FontIcon Glyph="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                        </Button>
                    </StackPanel>
                    <TextBlock
                        x:Name="MonthYearText"
                        Text="June 2026"
                        FontSize="22"
                        FontWeight="SemiBold"
                        VerticalAlignment="Center"
                        Margin="4,0,0,0"/>
                </StackPanel>

                <!-- View Switcher (Right): segmented Month / Week -->
                <Border Grid.Column="2" VerticalAlignment="Center"
                        Background="#2A2B2F" CornerRadius="7" Padding="3"
                        BorderBrush="#17FFFFFF" BorderThickness="1">
                    <StackPanel Orientation="Horizontal" Spacing="2">
                        <ToggleButton x:Name="MonthViewToggle" Content="Month" Padding="16,4"
                                      BorderThickness="0" IsChecked="True"/>
                        <ToggleButton x:Name="WeekViewToggle" Content="Week" Padding="16,4"
                                      BorderThickness="0"/>
                        <ToggleButton x:Name="DayViewToggle" Content="Day" Padding="16,4"
                                      BorderThickness="0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Month View -->
            <Grid x:Name="MonthViewRoot" Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Day Name Headers (Sun–Sat) -->
                <Grid x:Name="DayNamesGrid" Grid.Row="0" Height="30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                </Grid>

                <!-- Calendar Grid (7 columns, variable rows) -->
                <Grid x:Name="CalendarGrid" Grid.Row="1"/>
            </Grid>

            <!-- Week View (7 day columns; populated by WeekViewRenderer) -->
            <Grid x:Name="WeekViewRoot" Grid.Row="1" Visibility="Collapsed"/>

            <!-- Day View (all-day band + 24h timeline; populated by DayViewRenderer) -->
            <Grid x:Name="DayViewRoot" Grid.Row="1" Visibility="Collapsed"/>
        </Grid>
    </Grid>
</Window>
