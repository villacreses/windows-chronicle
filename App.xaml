<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="Chronicle.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Chronicle"
    RequestedTheme="Dark">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!-- Other merged dictionaries here -->
            </ResourceDictionary.MergedDictionaries>

            <!-- Teal-green accent applied across all accent-aware controls
                 (accent buttons, toggles, ContentDialog primary, focus). -->
            <Color x:Key="SystemAccentColor">#2E9B7C</Color>
            <Color x:Key="SystemAccentColorLight1">#38AD8B</Color>
            <Color x:Key="SystemAccentColorLight2">#5BC8A4</Color>
            <Color x:Key="SystemAccentColorLight3">#7FD8BB</Color>
            <Color x:Key="SystemAccentColorDark1">#1A7F64</Color>
            <Color x:Key="SystemAccentColorDark2">#14684F</Color>
            <Color x:Key="SystemAccentColorDark3">#0E5340</Color>
        </ResourceDictionary>
    </Application.Resources>
</Application>
